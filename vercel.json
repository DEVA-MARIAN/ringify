{
  "version": 2,
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "pages/api/extract.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "pages/api/trim.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "pages/api/audio/[filename].ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "pages/api/health.ts": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "env": {
    "NEXT_PUBLIC_APP_URL": "https://your-app.vercel.app"
  }
}


