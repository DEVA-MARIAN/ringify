# Copy this file to .env.local for local development

# Base URL of the app (used for serving audio files)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Set paths to custom ffmpeg/yt-dlp binaries
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# YTDLP_PATH=/usr/local/bin/yt-dlp

# Optional: Cloud storage (for production - swap out local file serving)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1

# Optional: Set max upload size or processing timeout
# MAX_AUDIO_DURATION_SECONDS=600
# PROCESSING_TIMEOUT_MS=120000
